model {
    extend cp.case-administration-subdomain {
        advocate-portal = product {
            title 'Advocate Portal'
            description 'Provides access to cases for defence advocates'

            defence-ui = user-interface {
                title 'Defence UI'
                technology 'Angular'
                summary 'Provides access to cases for defence advocates'
                metadata {
                    language 'TypeScript'
                    software-framework 'Angular'
                }
                style {
                    icon tech:angular
                }
                link https://github.com/hmcts/cpp-ui-defence 'Repository'

                this -> defence-service 'makes API calls to'
            }

            defence-service = microservice {
                title 'Advocate Service'
                technology 'Java EE'
                metadata {
                    language 'Java'
                    software-framework 'Java EE 8'
                }
                link https://github.com/hmcts/cpp-context-defence 'Repository'
                this -> cp.material-service 'Provides IDPC access for defence representatives'
                this -> cp.listing-service 'Retrieves listing information for (unallocated) hearings associated with cases and applications of defence clients'
                this -> cp.hearing-service 'Retrieves hearing information related to cases and application belonging to defence clients'
                this -> cp.progression-service 'Retrieves case, application and hearing details related to defence clients'
                this -> cp.reference-data 'Retrieves prosecutor information and public holiday information for data calculations'
                this -> cp.reference-data-offences 'Retrieves offence particular information related to offences the defence client is being charged with'
                this -> cp.users-and-groups 'Used for RBAC controls'                
                this -> defence-database
                this -> cp.shared-components-subdomain.file-service-system.file-service-database {
                    title 'stores OPA documents'
                    description 'Stores PDF documents generated for Online Plea and Allocation (OPA) proceedings, linked as case materials'
                }
                this -[mi]-> cp.management-information-system.mi-report-data-service 'sends data to'

                // TODO @Matthew.Rich - Needs to be removed from code then updated here
                this -> cp.document-generator 'Used for OPA (Online Plea/Allocation) which is believed to have been descoped and needs to be removed, along with File Service usage'
            }

            defence-database = datastore {
                title 'Defence Database'
                technology 'PostgreSQL'
                summary 'Stores events and entities'
                style {
                    icon tech:postgresql
                }
            }
        }
    }
}